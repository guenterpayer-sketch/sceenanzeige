    {
      "key": "format_datum",
      "type": "select",
      "label": "Datumsformat",
      "default": "d.m.Y",
      "options": [
        { "value": "d.m.Y", "label": "31.12.2026" },
        { "value": "l, d.m.Y", "label": "Donnerstag, 31.12.2026" }
      ]
    }
  ]
