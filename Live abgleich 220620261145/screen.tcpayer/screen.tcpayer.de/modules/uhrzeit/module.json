      "key": "format_zeit",
      "type": "select",
      "label": "Zeitformat",
      "default": "H:i",
      "options": [
        { "value": "H:i", "label": "24h, z.B. 14:05" },
        { "value": "H:i:s", "label": "24h mit Sekunden, z.B. 14:05:32" },
