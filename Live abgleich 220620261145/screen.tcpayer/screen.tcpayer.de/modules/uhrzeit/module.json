{
  "id": "uhrzeit",
  "label": "Uhrzeit & Datum",
  "icon": "clock",
  "has_proxy": false,
  "has_inhalte": false,
  "settings": [
    { "key": "zeige_datum", "type": "bool", "label": "Datum anzeigen", "default": true },
