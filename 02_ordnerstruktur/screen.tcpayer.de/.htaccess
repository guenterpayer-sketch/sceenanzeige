# ============================================================================
# screen.tcpayer.de — Backend / Admin
# ============================================================================

# PHP-Version (all-inkl KAS: ggf. anpassen, falls per .htaccess gesteuert)
# AddHandler application/x-httpd-php8 .php

# UTF-8 als Standard-Zeichensatz
AddDefaultCharset UTF-8

# Verzeichnis-Listing global deaktivieren
Options -Indexes

# ----------------------------------------------------------------------------
# Zugriffsschutz: config.php (DB-Zugangsdaten) darf niemals direkt aufrufbar
# sein, egal wo sie liegt.
# ----------------------------------------------------------------------------
<FilesMatch "^config\.php$">
    Require all denied
</FilesMatch>

# ----------------------------------------------------------------------------
# Schutz von Includes: /includes/ enthält nur PHP-Klassen/Helper, die per
# require/include eingebunden werden — kein Direktaufruf nötig.
# ----------------------------------------------------------------------------
<IfModule mod_alias.c>
    RedirectMatch 403 ^/includes/
</IfModule>

# Hinweis: uploads/ hat eine eigene .htaccess, die PHP-Ausführung dort
# deaktiviert (siehe uploads/.htaccess) — Schutz gegen Upload-Exploits.

# ----------------------------------------------------------------------------
# CORS: alle Subdomains dürfen Bilder/Proxies von hier laden.
# Neue Säle funktionieren automatisch ohne Anpassung.
# ----------------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"

    # JS/CSS immer beim Server rückfragen (Cache-Revalidierung via ETag →
    # billige 304er). Verhindert, dass Monitore/Browser nach einem Deploy
    # mit veraltetem monitor.js / module-loader.js / monitor.css laufen —
    # die Monitor-HTMLs laden diese Dateien ohne Cache-Buster.
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>
